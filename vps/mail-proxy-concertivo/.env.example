# ===========================================
# Mail Proxy — Concertivo
# Skopiuj na .env i wypełnij wszystkie 4 pola.
# ===========================================

# Adres zewnętrznej bazy Supabase Concertivo (ten sam co VITE_SUPABASE_URL w Lovable)
SUPABASE_URL=https://rpnucwqjtnxfflwqpcgg.supabase.co

# Service role key bazy Concertivo (panel Supabase → Settings → API → service_role)
SUPABASE_SERVICE_ROLE_KEY=

# 32-bajtowy klucz hex do szyfrowania haseł SMTP/IMAP.
# Wygeneruj: openssl rand -hex 32
# UWAGA: MUSI być inny niż w instancji CRM Hub.
# Ten sam klucz musisz wrzucić do Lovable secrets jako MAIL_ENCRYPTION_KEY.
MAIL_ENCRYPTION_KEY=

# Token autoryzujący wywołania proxy (nagłówek X-Proxy-Token).
# Wygeneruj: openssl rand -hex 32
# Ten sam token musisz wrzucić do Lovable secrets jako MAIL_PROXY_TOKEN.
PROXY_TOKEN=
